

string vel = "I love vel\n";
uint64 msglen = 12;

void main() {
    for(int32 i=0;i<5;i++){
        %{
            mov rax, 1          ; syscall: write
            mov rdi, 1          ; file descriptor: stdout
            ; pointer to message in rsi
            mov rdx, rbx        ; message length
            syscall             ; invoke syscall
        }$ in(vel -> rsi, msglen -> rbx)%
    }
}
