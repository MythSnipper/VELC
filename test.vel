

string vel = "hello world!\n";
uint64 msglen = 13;

void main() {
    %{
        push rax
        mov rax, 1          ; syscall: write
        mov rdi, 1          ; file descriptor: stdout
        pop rsi             ; pointer to message
        mov rdx, rbx        ; message length
        syscall             ; invoke syscall
    }$ in(vel -> rax, msglen -> rbx)%
}
