
uint64 strlen(string str) {
    uint64 length = 0;
    while((*(char*)str) != 0){
        length++;
        str = (string)((uint64)str + 1);
    }
    return length;
}

//print functions
void print_char(char out) {
    char* outptr = &out;
    %{
        mov rax, 1          ; syscall: write
        mov rdi, 1          ; file descriptor: stdout
        ; pointer to message in rsi
        mov rdx, 1          ; message length
        syscall
    }$ in(outptr -> rsi)%
}

void print_str(string str) {
    uint64 len = strlen(str);
    %{
        mov rax, 1          ; syscall: write
        mov rdi, 1          ; file descriptor: stdout
        ; pointer to message in rsi
        ; message length in rdx
        syscall
    }$ in(str -> rsi, len -> rdx)%
}

void print_uint(uint64 num) {
    if (num >= 10) {
        print_uint(num / 10);
    }
    print_char((char)((num % 10) + '0'));
}

void print_int(int64 num) {
    if (num < 0) {
        print_char('-');
        print_uint((uint64)(0-num));
    }
    else{
        print_uint((uint64)num);
    }
}

void print_bool(bool value) {
    if(value) {
        print_str("true");
        return;
    }
    print_str("false");
}

void println(string str) {
    print_str(str);
    print_char('\n');
}

void __print_hex_digit(uint64 digit) {
    if(digit < 10) {
        print_char((char)(digit + '0'));
    }
    else {
        print_char((char)((digit - 10) + 'a'));
    }
}
void __print_hex_uint64_inner(uint64 value) {
    if(value >= 16) {
        __print_hex_uint64_inner(value / 16);
    }
    __print_hex_digit(value % 16);
}

void print_hex(uint64 value) {
    print_str("0x");
    __print_hex_uint64_inner(value);
}

uint64 main() {
    string man = "hiiiiiiiiiiiiiiiiiiii ywesan  quween UYEAAAHG OMG HWGHUIOWRHTHWEIOERHAITOHDROTHOEH SMASH WEJOTUOWERJTOPUWEORPUTOEROTEROTU OIUOIDSFIDOEWR";
    for(int32 i = 0; i < strlen(man); i++) {
        print_char(*(char*)((uint64)man + i));
        println("");
    }
    return 0;
}




